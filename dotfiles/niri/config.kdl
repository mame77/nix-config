hotkey-overlay {
    skip-at-startup
}
workspace "one"
workspace "two"
gestures {
    hot-corners {
        off
    }
}
cursor {
    hide-when-typing
}
input {
    keyboard {
        xkb {
            layout "us"
            options "ctrl:nocaps"
        }
        numlock
        repeat-delay 300
        repeat-rate 30
    }
    touchpad {
        tap
        natural-scroll
        scroll-factor 0.5
    }
}
output "eDP-1" {
    mode "1920x1080@60"
    scale 1.25
    position x=0 y=0
}
output "HDMI-A-1" {
    mode "1920x1080@60"
    position x=1536 y=0
}
layout {
    gaps 16
    default-column-width { proportion 1.0; }
    preset-column-widths {
        proportion 0.5
        proportion 1.0
    }
    focus-ring { width 1; active-color "#1e66f5"; }
}

// xwayland (Handy/Enigo が必要とする X11 サーバ。niri 26.04+ builtin)。
// xwayland-satellite が PATH にあると niri が自動で socket 作成 + DISPLAY 設定。
xwayland-satellite {
    path "xwayland-satellite"
}

window-rule {
    open-maximized false
    draw-border-with-background false
    geometry-corner-radius 12
    clip-to-geometry true
    opacity 0.95
}
window-rule {
    match app-id=r#"^vivaldi-.*-Default$"#
    open-maximized false
    default-column-width { fixed 1504; }
    default-window-height { fixed 884; }
    default-floating-position x=0 y=0 relative-to="top-left"
    geometry-corner-radius 12
    clip-to-geometry true
    draw-border-with-background false
}
window-rule {
    match app-id="TUI.float"
    open-floating true
    opacity 0.95
}
animations {
     workspace-switch {
         spring damping-ratio=1.0 stiffness=5000 epsilon=0.0001
     }
     window-movement {
         spring damping-ratio=1.0 stiffness=5000 epsilon=0.0001
     }
     horizontal-view-movement {
         spring damping-ratio=1.0 stiffness=5000 epsilon=0.0001
     }
 }
screenshot-path "~/Images/Screenshot from %m-%d %H-%M.png"
prefer-no-csd
spawn-at-startup "sh" "-c" "/home/mame/.config/niri/scripts/battery-monitor.sh"
spawn-at-startup "fcitx5"
environment {
    DISPLAY ":1"
    XDG_SESSION_TYPE "wayland"
    QT_QPA_PLATFORM "wayland"
    GDK_BACKEND "wayland"
    MOZ_ENABLE_WAYLAND "1"
    GTK_THEME "Adwaita"
    QT_STYLE_OVERRIDE "Adwaita"
    GTK_IM_MODULE "fcitx"
    QT_IM_MODULE "fcitx"
    XMODIFIERS "@im=fcitx"
    INPUT_METHOD "fcitx"
    SDL_IM_MODULE "fcitx"
}

binds {
    // app
    Mod+B     { spawn-sh "/home/mame/.config/niri/scripts/obsidian-vault.sh"; }
    Mod+C     { spawn "vivaldi"; }
    Mod+F     { spawn "fuzzel"; }
    Mod+V     { spawn-sh "/home/mame/.local/opt/OpenCode/ai.opencode.desktop --no-sandbox"; }
    Mod+W     { spawn "sh" "-c" "/home/mame/.config/niri/scripts/codex-desktop.sh"; }
    Mod+R     { spawn "wlogout"; }
    Mod+T     { spawn-sh "ghostty --class='app' --command='tmux'"; }
    Mod+Shift+T     { spawn-sh "ghostty --class='app' --command='env TERM=xterm-256color ssh -tt server'"; }
    Mod+Shift+W     { spawn "chromium"; }
    // web
    Mod+G     { spawn-sh "vivaldi --new-window --window-size=1504,884 --app='https://grok.com/'"; }
    Mod+S     { spawn-sh "vivaldi --new-window --window-size=1504,884 --app='https://app.slack.com/client/'"; }
    Mod+D     { spawn-sh "vivaldi --new-window --window-size=1504,884 --app='https://discord.com/app'"; }
    Mod+Y     { spawn-sh "vivaldi --new-window --window-size=1504,884 --app='https://www.youtube.com'"; }
    // system
    Mod+Q     { close-window; }
    Mod+1     { spawn-sh "ghostty --class='TUI.float' --command='bluetuith'"; }
    Mod+2     { spawn-sh "ghostty --class='TUI.float' --command='wiremix'"; }
    Mod+3     { spawn-sh "ghostty --class='TUI.float' --command='impala'"; }
    Mod+4     { spawn-sh "ghostty --class='app'       --command='btop'"; }
    Mod+5     { spawn "sh" "-c" "wl-mirror eDP-1"; }
    // move
    Mod+H     { focus-column-left; }
    Mod+J     { focus-workspace-down; }
    Mod+K     { focus-workspace-up; }
    Mod+L     { focus-column-right; }
    Mod+Shift+H { focus-monitor-left; }
    Mod+Shift+L { focus-monitor-right; }
    // move column
    Mod+Ctrl+H     { move-column-left; }
    Mod+Ctrl+L     { move-column-right; }
    Mod+Ctrl+J     { move-column-to-workspace-down; }
    Mod+Ctrl+K     { move-column-to-workspace-up; }
    Mod+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+L     { move-column-to-monitor-right; }
    // column size
    Mod+O         { switch-preset-column-width; }
    Mod+Shift+O   { fullscreen-window; }
    // bright
    F1 { spawn "sh" "-c" "/home/mame/.config/niri/scripts/brightness.sh 10%-"; }
    F2 { spawn "sh" "-c" "/home/mame/.config/niri/scripts/brightness.sh 10%+"; }
    // record
    Mod+Z { spawn "sh" "-c" "noctalia msg plugin noctalia/screen_recorder:service all toggle";}
    Mod+X { screenshot; }
    // handy (speech-to-text)
    // Tauri グローバルショートカットは Niri 上で発火しないため、
    // niri の binds から handy の CLI シグナルを送る。
    // push-to-talk は使えず、トグル動作になる (toggle で十分なら OK)。
    Ctrl+Slash        { spawn "handy" "--toggle-transcription"; }
    Ctrl+Shift+Space  { spawn "handy" "--toggle-post-process"; }
    Escape            { spawn "handy" "--cancel"; }
    // off
    Mod+Shift+E   { quit; }
}
